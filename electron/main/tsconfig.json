{
    "extends": "../tsconfig.json",
    "exclude": [
        "test",
        "dist",
    ],
    "compilerOptions": {
        "rootDir": ".",
        "target": "es6",
        "outDir": "../dist",
        "noEmit": false,
        "module": "nodenext",
        "pretty": true,
        "verbatimModuleSyntax": false,
        "moduleResolution": "nodenext",
        "allowImportingTsExtensions": false,
        "paths": {
            "@/*": [
                "../main/*"
            ]
        }
    },
    "include": [
        "./"
    ]
}