{
    "name": "my-app",
    "version": "0.1.0",
    "private": true,
    "main": "./dist/index.js",
    "homepage": ".",
    "scripts": {
        "start": "node bin/pre-load-configuration.js && node bin/start.js",
        "pack": "node bin/pre-load-configuration.js && node bin/pack.js",
        "make": "node bin/pre-load-configuration.js && node bin/make.js"
    },
    "browserslist": {
        "production": [
            "last 1 chrome version"
        ],
        "development": [
            "last 1 chrome version"
        ]
    },
    "build": {
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "appImage"
        },
        "mac": {
            "target": "dmg"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "deleteAppDataOnUninstall": true,
            "guid": "b5a96e2b-5f4f-4a67-b77a-2c9d7c947242",
            "runAfterFinish": true,
            "allowToChangeInstallationDirectory": true
        },
        "appImage": {},
        "dmg": {},
        "appId": "com.electron.electron",
        "extends": null,
        "files": [
            "dist",
            "public",
            "build"
        ],
        "directories": {
            "output": "output"
        },
        "asar": {
            "smartUnpack": true
        },
        "asarUnpack": [
            "public",
            "build",
            "node_modules/@electron/remote",
            "node_modules/node-os-utils"
        ]
    },
    "devDependencies": {
        "@babylonjs/core": "9.10.1",
